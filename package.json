{
  "name": "node-service-based-template",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev-ts": "pnpm prettier-ts && nodemon src-typescript/server.ts --config nodemon-ts.json",
    "dev-js": "pnpm prettier-js && nodemon src-javascript/server.js --config nodemon-js.json",
    "proto:build-ts": "bash scripts/proto-gen.sh src-typescript/proto",
    "proto:build-js": "bash scripts/proto-gen.sh src-javascript/proto",
    "postinstall-ts": "bash scripts/proto-gen.sh src-typescript/proto || echo '[proto] generation skipped - run: pnpm proto:build-ts'",
    "postinstall-js": "bash scripts/proto-gen.sh src-javascript/proto || echo '[proto] generation skipped - run: pnpm proto:build-js'",
    "keys:generate": "bash scripts/generate-keys.sh",
    "build": "pnpm proto:build-ts && tsc && copyfiles -u 1 \"src-typescript/**/*.{css,html,ico,png,svg,proto}\" dist/ && copyfiles swagger.json dist/",
    "start-ts": "ts-node src-typescript/server.ts",
    "start-js": "node src-javascript/server.js",
    "preview": "node dist/server.js",
    "prettier-ts": "prettier --write \"src-typescript/**/*.ts\"",
    "prettier-js": "prettier --write \"src-javascript/**/*.js\"",
    "format:check": "prettier --check .",
    "lint": "eslint"
  },
  "author": "Ijlal Ahmad",
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.11.3",
    "@grpc/proto-loader": "^0.7.13",
    "@grpc/reflection": "^1.0.4",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "joi": "^17.11.0",
    "joi-to-swagger": "^6.2.0",
    "jose": "^5.9.6",
    "mongoose": "^8.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "process": "^0.11.10",
    "reflect-metadata": "^0.2.1",
    "sequelize": "^6.35.2",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.7.2",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.12.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "copyfiles": "^2.4.1",
    "eslint": "9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^15.11.0",
    "grpc-tools": "^1.12.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.8.5",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.2.5",
    "typescript": "^5.4.5"
  }
}
