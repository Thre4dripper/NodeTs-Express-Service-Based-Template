# ─── Runtime ──────────────────────────────────────────────────────────────────
PORT=8000
GRPC_PORT=50051
# development | dev | local enable Swagger UI, gRPC reflection & pretty logs
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# choose between postgres, mysql, mongodb, sqlite, mssql, db2, snowflake, oracle
DB_DIALECT=mongodb

# for postgres, mysql, mariadb, mssql, db2, snowflake, oracle
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=password

# for mongodb
MONGO_URI=mongodb://127.0.0.1:27017/Test

# ─── Database SSL/TLS (applies to both Mongoose & Sequelize) ──────────────────
DB_SSL=false
# when DB_SSL=true: reject self-signed / invalid certs (set false for self-signed)
DB_SSL_REJECT_UNAUTHORIZED=true
# optional absolute path to a CA bundle (PEM)
DB_SSL_CA_FILE=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
# set true to connect over TLS (rediss://)
REDIS_TLS=false

# ─── JWT / JWKS (RS256) ───────────────────────────────────────────────────────
# Generate with: pnpm keys:generate  (writes keys/private.pem)
# Provide EITHER an inline PEM (\n-escaped) OR a path to the private key file.
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_PATH=keys/private.pem

# ─── Logging ──────────────────────────────────────────────────────────────────
# trace|debug|info|warn|error|fatal
LOG_LEVEL=info
# stdout (default) | datadog | loki | otlp  — pluggable pino transport target
LOG_TRANSPORT=stdout

# ─── gRPC client examples (service-to-service consumer) ───────────────────────
# Address of a remote gRPC service this app may call (see app/examples/rpc.client)
REMOTE_SERVICE_GRPC_ADDRESS=localhost:50051
# dev-only gRPC UI proxy target
GRPC_UI_URL=http://localhost:8080